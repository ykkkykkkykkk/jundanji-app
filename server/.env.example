PORT=3001
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
FRONTEND_URL=https://your-app.vercel.app

# 개인정보 암호화 키 (AES-256-GCM) - 반드시 설정 필요
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_key_here
ADMIN_PASSWORD=your_admin_password_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here

# Web Push (VAPID) - 아래 명령으로 생성: node -e "const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@your-app.com

# 카카오 로그인
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://your-backend.onrender.com/api/auth/kakao/callback

# 구글 로그인
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/api/auth/google/callback

# Turso DB (프로덕션 전용 — 로컬은 SQLite 자동 사용)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Vercel Cron 보안 (선택)
CRON_SECRET=

# 개발용 더미 데이터 삽입 (로컬 개발 시에만 true 설정)
# 프로덕션에서는 설정하지 않음 → 전단지/알림/퀴즈 더미 데이터 삽입 안 됨
ENABLE_SEED_DATA=true
